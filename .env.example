# otp-relay configuration. Copy to .env for local dev.
#
# In production these are stored in the VPS secrets-manager under the
# OTP_RELAY_BACKEND_* prefix and injected at deploy time by vps-deploy.
# (e.g. secret OTP_RELAY_BACKEND_TOTP_SECRET -> TOTP_SECRET inside the container)

# --- Server ---
# Port the relay listens on INSIDE the container. The shared VPS Nginx proxies
# an auto-assigned host port (APP_PORT) to this. Leave at 8080.
RELAY_PORT=8080

# Set to "development" for local plain-HTTP testing (disables the Secure flag on
# the session cookie so login works over http://localhost). Omit in production.
# RELAY_ENV=development

# --- SQLite ---
# In production this is the mounted Docker volume. For local dev use ./data/relay.db
DB_PATH=/data/relay.db

# --- TOTP (dashboard login) ---
# Generate with: go run ./cmd/gen-totp-secret
TOTP_SECRET=

# --- Web Push (VAPID) ---
# Generate with: go run ./cmd/gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@sarvinshrivastava.space

# --- Claim window (dual-claim invalidation) ---
CLAIM_WINDOW_MS=7000

# --- OTP TTL (must be >= 30s; real OTPs live 1-5 min) ---
OTP_TTL_MS=120000

# --- Session ---
# A long random string used to sign session cookies (HMAC).
# Generate with: openssl rand -hex 32
SESSION_SECRET=
SESSION_DURATION_HOURS=24
